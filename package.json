    "babel-plugin-react-compiler": "^1.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.49",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.98.2",
    "typescript": "^6.0.2"
  }
