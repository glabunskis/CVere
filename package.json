{
  "name": "cvere",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "email:build": "email build",
    "email:dev": "email dev --dir ./src/features/emails --port 3001",
    "email:export": "email export",
    "stripe:listen": "stripe listen --forward-to=localhost:3000/api/webhooks --project-name=cvere",
    "generate-types": "npx supabase gen types typescript --project-id vjklhmtexivjfxzpsciz --schema public > src/libs/supabase/types.ts",
    "supabase:link": "env-cmd -f ./.env.local supabase link --project-ref vjklhmtexivjfxzpsciz",
    "migration:new": "supabase migration new",
    "migration:up": "env-cmd -f ./.env.local supabase migration up --linked --debug && npm run generate-types",
    "migration:squash": "env-cmd -f ./.env.local supabase migration squash --linked"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/react": "^3.0.184",
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "^1.0.12",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.182",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-safe-action": "^8.4.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-email": "^5.2.10",
    "react-hook-form": "^7.72.1",
    "resend": "^6.10.0",
    "resumable-stream": "^2.2.12",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
