# Update these with your Supabase details from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=UPDATE_THIS_wITH_YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=UPDATE_THIS_wITH_YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=UPDATE_THIS_wITH_YOUR_SUPABASE_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_DB_PASSWORD=UPDATE_THIS_wITH_YOUR_SUPABASE_SUPABASE_DB_PASSWORD

# Update these with your Stripe credentials from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=UPDATE_THIS_wITH_YOUR_STRIPE_PK
STRIPE_SECRET_KEY=UPDATE_THIS_wITH_YOUR_STRIPE_SK
STRIPE_WEBHOOK_SECRET=UPDATE_THIS_wITH_YOUR_STRIPE_WHSEC

# Update this with your resend.com credentials from https://resend.com/api-keys
RESEND_API_KEY=re_test_1234

# Env
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI provider
# Recommended for dev: openai. Use stub for fully offline / deterministic runs.
# stub | openai
AI_PROVIDER=openai
# 0 to disable, 0.0 - 1.0 to simulate transient failures from the stub
AI_STUB_FAILURE_RATE=0

# OpenAI (required when AI_PROVIDER=openai or for the chat route)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
# Optional. Override only if pointing at an OpenAI-compatible gateway/proxy.
OPENAI_BASE_URL=

# Feature gates
# When true, /api/chat enforces an active Pro subscription. Off by default in dev.
CHAT_REQUIRE_SUBSCRIPTION=false

# Upstash Redis (REST credentials) — used by the resumable chat stream.
# Get these from https://console.upstash.com (database → REST API tab).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
